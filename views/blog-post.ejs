<%- include('partials/header') %>
<%- include('partials/navbar') %>

<section class="max-w-3xl mx-auto px-6 pt-8">
  <nav class="text-sm text-ink-900/50 mb-6">
    <a href="/" class="hover:text-forest-700">Home</a> <span class="mx-1">&rsaquo;</span>
    <a href="/blog" class="hover:text-forest-700">Blog</a> <span class="mx-1">&rsaquo;</span>
    <span class="text-ink-900">Article</span>
  </nav>

  <div class="rounded-3xl h-56 md:h-72 mb-8 overflow-hidden" style="background: linear-gradient(135deg, #E4D4F5 0%, #F1E9FA 100%);"></div>

  <h1 class="font-display text-3xl md:text-4xl font-semibold text-ink-900 mb-8 leading-tight"><%= post.title %></h1>

  <div class="prose text-ink-900/80 leading-relaxed space-y-5">
    <% post.body.split('\n\n').forEach(function(paragraph) { %>
      <p><%= paragraph %></p>
    <% }); %>
  </div>

  <div class="mt-10 pt-8 border-t border-mint-200">
    <a href="/blog" class="inline-flex items-center gap-2 text-forest-700 font-semibold text-sm hover:text-ink-900">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
      Back to Blog
    </a>
  </div>
</section>

<section class="max-w-7xl mx-auto px-6 py-16">
</section>

<%- include('partials/bottom-nav') %>
<%- include('partials/footer') %>