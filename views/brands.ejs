<%- include('partials/header') %>
<%- include('partials/navbar') %>

<section class="max-w-7xl mx-auto px-6 pt-8">
  <nav class="text-sm text-ink-900/50 mb-4">
    <a href="/" class="hover:text-forest-700">Home</a> <span class="mx-1">&rsaquo;</span> <span class="text-ink-900">Shop by Brand</span>
  </nav>
  <h1 class="font-display text-3xl md:text-4xl font-semibold text-ink-900 mb-2">Shop by Brand</h1>
  <p class="text-ink-900/60 max-w-xl">Browse products from your trusted, favorite brands.</p>
</section>

<section class="max-w-7xl mx-auto px-6 py-10">
  <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-5">
    <% const brands = [
      'CeraVe', 'La Roche-Posay', 'Garnier', 'Eucerin', 'Centrum', 'Benylin',
      'Aptamil', 'Nestle NAN', 'Panadol', 'Vitabiotics', 'Jamieson', 'Dr. Esthe'
    ]; %>
    <% brands.forEach(function(b) { %>
      <a href="/brand/<%= b.toLowerCase().replace(/[^a-z0-9]+/g, '-') %>" class="bg-white border border-mint-200 rounded-2xl p-6 flex items-center justify-center text-center hover:border-forest-700 hover:shadow-md transition-all h-24">
        <span class="font-semibold text-ink-900 text-sm"><%= b %></span>
      </a>
    <% }); %>
  </div>
</section>

<%- include('partials/bottom-nav') %>
<%- include('partials/footer') %>