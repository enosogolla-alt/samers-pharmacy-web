<%- include('partials/header') %>
<%- include('partials/navbar') %>

<section class="max-w-7xl mx-auto px-6 pt-8">
  <nav class="text-sm text-ink-900/50 mb-4">
    <a href="/" class="hover:text-forest-700">Home</a> <span class="mx-1">&rsaquo;</span> <span class="text-ink-900">Shop by Category</span>
  </nav>
  <h1 class="font-display text-3xl md:text-4xl font-semibold text-ink-900 mb-2">Shop by Category</h1>
  <p class="text-ink-900/60 max-w-xl">Browse our wide range of health and wellness products. From pain relief to vitamins, we have everything you need for your health.</p>
</section>

<section class="max-w-7xl mx-auto px-6 py-10">
  <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
    <% const categories = [
      { name: 'Medicines & Prescriptions', slug: 'medicines', bg: 'bg-mint-50', icon: 'M9 12h3.75M9 15h3.75M3.75 5.25h6.5v6.5h-6.5v-6.5z' },
      { name: 'Vitamins & Supplements', slug: 'vitamins-supplements', bg: 'bg-[#FDF3E3]', icon: 'M12 8v8m-4-4h8m6 0a10 10 0 11-20 0 10 10 0 0120 0z' },
      { name: 'Skincare & Beauty', slug: 'skincare-beauty', bg: 'bg-[#FBEAF0]', icon: 'M12 4.5c3.5 0 6.5 3 6.5 7s-3 7-6.5 7-6.5-3-6.5-7 3-7 6.5-7z' },
      { name: 'Mother & Baby', slug: 'mother-baby', bg: 'bg-[#EAF1FB]', icon: 'M12 4a4 4 0 100 8 4 4 0 000-8zm-7 16a7 7 0 0114 0' },
      { name: 'Medical Devices', slug: 'medical-devices', bg: 'bg-[#F1EEFB]', icon: 'M9 3v2m6-2v2M4 8h16M5 8v11a2 2 0 002 2h10a2 2 0 002-2V8H5z' },
      { name: 'Personal Care', slug: 'personal-care', bg: 'bg-[#EAFBF3]', icon: 'M12 2v2m0 16v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M2 12h2m16 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42' },
      { name: 'Bone, Joint & Muscle', slug: 'bone-joint-muscle', bg: 'bg-[#FDF3E3]', icon: 'M6 18L18 6M9 6h9v9' },
      { name: 'Analgesics & Painkillers', slug: 'analgesics-painkillers', bg: 'bg-[#FBEAEA]', icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
      { name: 'Health Conditions', slug: 'health-conditions', bg: 'bg-[#EAF1FB]', icon: 'M3 12h4l2-7 4 14 2-7h6' },
      { name: 'Reproductive & Sexual Health', slug: 'reproductive-sexual-health', bg: 'bg-[#FBEAF0]', icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z' },
      { name: 'Baby Products', slug: 'baby-products', bg: 'bg-[#F1EEFB]', icon: 'M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z' },
      { name: 'IV Therapy', slug: 'iv-therapy', bg: 'bg-[#EAFBF3]', icon: 'M12 3v18M8 7l4-4 4 4M8 17l4 4 4-4' },
    ]; %>
    <% categories.forEach(function(cat) { %>
      <a href="/category/<%= cat.slug %>" class="<%= cat.bg %> rounded-2xl p-5 flex items-center justify-between gap-3 hover:shadow-md transition-shadow group">
        <div class="flex items-center gap-3">
          <span class="w-11 h-11 rounded-xl bg-white flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-forest-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="<%= cat.icon %>"/></svg>
          </span>
          <span class="font-semibold text-ink-900 text-sm leading-snug"><%= cat.name %></span>
        </div>
        <svg class="w-4 h-4 text-ink-900/30 group-hover:text-forest-700 transition-colors shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </a>
    <% }); %>
  </div>
</section>

<%- include('partials/bottom-nav') %>
<%- include('partials/footer') %>