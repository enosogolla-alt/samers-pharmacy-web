<%- include('partials/header') %> <%- include('partials/navbar') %>


<!-- ============ PROMO CAROUSEL ============ -->
<section class="max-w-7xl mx-auto px-6 pt-8 pb-16" x-data="{ slide: 0, slides: 3 }" x-init="setInterval(() => slide = (slide + 1) % slides, 4000)">
  <div class="relative rounded-3xl overflow-hidden h-64 md:h-80">

    <div class="absolute inset-0 flex transition-transform duration-700 ease-in-out" :style="`transform: translateX(-${slide * 100}%)`">

      <div class="min-w-full h-full bg-forest-700 flex items-center px-10 md:px-16">
        <div>
          <span class="inline-block px-3 py-1 rounded-capsule bg-white/15 text-mint-400 text-xs font-semibold mb-3">Limited Offer</span>
          <h3 class="font-display text-2xl md:text-3xl text-white font-semibold mb-2">Up to 15% off vitamins</h3>
          <p class="text-white/70 text-sm md:text-base">Boost your immunity this season</p>
        </div>
      </div>

      <div class="min-w-full h-full bg-ink-900 flex items-center px-10 md:px-16">
        <div>
          <span class="inline-block px-3 py-1 rounded-capsule bg-gold-500/20 text-gold-500 text-xs font-semibold mb-3">New</span>
          <h3 class="font-display text-2xl md:text-3xl text-white font-semibold mb-2">Home lab sample collection</h3>
          <p class="text-white/70 text-sm md:text-base">Book a test, we come to you</p>
        </div>
      </div>

      <div class="min-w-full h-full bg-mint-400 flex items-center px-10 md:px-16">
        <div>
          <span class="inline-block px-3 py-1 rounded-capsule bg-ink-900/10 text-ink-900 text-xs font-semibold mb-3">Free Delivery</span>
          <h3 class="font-display text-2xl md:text-3xl text-ink-900 font-semibold mb-2">On orders above KSh 2,500</h3>
          <p class="text-ink-900/70 text-sm md:text-base">Nationwide, fast and reliable</p>
        </div>
      </div>

    </div>

    <div class="absolute bottom-5 left-1/2 -translate-x-1/2 flex gap-2">
      <template x-for="i in slides">
        <button @click="slide = i - 1" class="w-2 h-2 rounded-full transition-all" :class="slide === i - 1 ? 'bg-white w-6' : 'bg-white/40'"></button>
      </template>
    </div>
  </div>
</section>

<!-- ============ BRAND STATEMENT ============ -->
<section class="max-w-4xl mx-auto px-6 py-14 text-center">
<div class="flex items-center justify-center gap-2 mb-5">
 <img src="/images/logo-icon.png" alt="Samers Pharmacy" class="w-10 h-10 object-contain mix-blend-multiply">
  <span class="font-display font-semibold text-xl text-forest-700">Samers Pharmacy</span>
</div>
  <h2 class="font-display text-2xl md:text-3xl font-semibold text-ink-900 leading-snug">
    Trusted care, delivered with precision — because your health deserves nothing less than genuine medicine, real expertise, and a pharmacy that shows up.
  </h2>
</section>

<!-- ============ TODAY'S OFFERS ============ -->
<section class="max-w-7xl mx-auto px-6 py-4 pb-16">
  <div class="flex items-end justify-between mb-8">
    <div>
      <h2 class="font-display text-2xl md:text-3xl font-semibold text-ink-900">Today's Offers</h2>
      <p class="text-ink-900/60 mt-1">Genuine products, real savings</p>
    </div>
    <a href="#" class="text-forest-700 font-semibold text-sm flex items-center gap-1 hover:text-ink-900">
      View All
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
    </a>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-5 items-stretch">
    <% const offers = [
      { name: 'Vitamin C 1000mg Tablets', price: 850, oldPrice: 1000, discount: '15% OFF' },
      { name: 'Paracetamol 500mg (100s)', price: 320, oldPrice: 400, discount: '20% OFF' },
      { name: 'Digital Thermometer', price: 950, oldPrice: 1200, discount: '21% OFF' },
      { name: 'Multivitamin Syrup 200ml', price: 680, oldPrice: 800, discount: '15% OFF' },
    ]; %>
    <% offers.forEach(function(item) { %>
      <div class="bg-white border border-mint-200 rounded-2xl p-4 hover:shadow-md transition-shadow flex flex-col h-full">
        <div class="relative rounded-xl h-44 mb-5 flex items-center justify-center overflow-hidden" style="background: radial-gradient(circle at 50% 40%, #ffffff 0%, #F3F8F5 65%, #E9F7F2 100%);">
          <span class="absolute top-3 left-3 px-2.5 py-1 rounded-capsule bg-coral-500 text-white text-[10px] font-bold"><%= item.discount %></span>
          <svg class="w-14 h-14 text-mint-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M3.75 5.25h6.5v6.5h-6.5v-6.5z"/></svg>
        </div>
        <p class="text-sm font-medium text-ink-900 mb-2 leading-snug flex-1"><%= item.name %></p>
        <div class="flex items-baseline gap-1.5 mb-3 flex-wrap">
          <span class="text-gold-500 font-bold whitespace-nowrap">KSh <%= item.price %></span>
          <span class="text-ink-900/40 text-xs line-through whitespace-nowrap">KSh <%= item.oldPrice %></span>
        </div>
        <button class="w-full py-2 rounded-capsule bg-forest-700 text-white text-sm font-semibold hover:bg-ink-900 transition-colors">Add to Cart</button>
      </div>
    <% }); %>
  </div>
</section>

<!-- ============ SHOP BY CATEGORY ============ -->
<section class="max-w-7xl mx-auto px-6 py-16">
  <div class="flex items-end justify-between mb-8">
    <div>
      <h2 class="font-display text-2xl md:text-3xl font-semibold text-ink-900">Shop by Category</h2>
      <p class="text-ink-900/60 mt-1">Browse our wide range of healthcare products</p>
    </div>
    <a href="#" class="text-forest-700 font-semibold text-sm flex items-center gap-1 hover:text-ink-900">
      View All
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
    </a>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4">
    <% const categories = [
      { name: 'Medicines', icon: 'M9 12h3.75M9 15h3.75M3.75 5.25h6.5v6.5h-6.5v-6.5z' },
      { name: 'Vitamins & Supplements', icon: 'M12 8v8m-4-4h8m6 0a10 10 0 11-20 0 10 10 0 0120 0z' },
      { name: 'Skincare & Beauty', icon: 'M12 4.5c3.5 0 6.5 3 6.5 7s-3 7-6.5 7-6.5-3-6.5-7 3-7 6.5-7z' },
      { name: 'Mother & Baby', icon: 'M12 4a4 4 0 100 8 4 4 0 000-8zm-7 16a7 7 0 0114 0' },
      { name: 'Medical Devices', icon: 'M9 3v2m6-2v2M4 8h16M5 8v11a2 2 0 002 2h10a2 2 0 002-2V8H5z' },
      { name: 'Personal Care', icon: 'M12 2v2m0 16v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M2 12h2m16 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42' },
    ]; %>
    <% categories.forEach(function(cat) { %>
      <a href="#" class="group bg-white border border-mint-200 rounded-2xl p-5 flex flex-col items-center text-center gap-3 hover:border-forest-700 hover:shadow-md transition-all">
        <span class="w-12 h-12 rounded-full bg-mint-50 flex items-center justify-center group-hover:bg-forest-700 transition-colors">
          <svg class="w-6 h-6 text-forest-700 group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="<%= cat.icon %>"/></svg>
        </span>
        <span class="text-sm font-medium text-ink-900"><%= cat.name %></span>
      </a>
    <% }); %>
  </div>
</section>

