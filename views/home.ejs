  </div>
</section>

<!-- ============ LATEST ON THE BLOG ============ -->
<section class="max-w-7xl mx-auto px-6 py-16">
  <div class="flex items-end justify-between mb-8">
    <div>
      <h2 class="font-display text-2xl md:text-3xl font-semibold text-ink-900">Latest on the Blog</h2>
      <p class="text-ink-900/60 mt-1">Health tips, wellness guides, and expert insights</p>
    </div>
    <a href="#" class="text-forest-700 font-semibold text-sm flex items-center gap-1 hover:text-ink-900">
      View All
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
    </a>
  </div>

  <div class="flex gap-6 overflow-x-auto pb-4 -mx-6 px-6 snap-x snap-mandatory" style="scrollbar-width: none;">
    <% const posts = [
      { title: 'Mid-Year Reset: 7 Simple Self-Care Tips to Recharge', excerpt: "Halfway through the year, small habits can make a big difference to how you feel." },
      { title: 'Dry Skin vs. Dehydrated Skin — Why People Confuse Them', excerpt: 'Understanding the difference is the first step to treating either one correctly.' },
      { title: 'Why Being There Through Every Moment Matters', excerpt: 'From routine check-ups to life\'s bigger decisions, consistent care changes outcomes.' },
      { title: 'Managing Chronic Conditions Without Losing Yourself', excerpt: 'Practical, sustainable habits for living well alongside a long-term diagnosis.' },
    ]; %>
    <% posts.forEach(function(post) { %>
      <a href="#" class="min-w-[280px] md:min-w-[320px] snap-start group">
        <div class="rounded-2xl h-44 mb-4 overflow-hidden" style="background: linear-gradient(135deg, #BFE8D6 0%, #E9F7F2 100%);"></div>
        <h3 class="font-display text-lg font-semibold text-ink-900 mb-2 leading-snug group-hover:text-forest-700 transition-colors"><%= post.title %></h3>
        <p class="text-sm text-ink-900/60 mb-3 leading-relaxed"><%= post.excerpt %></p>
        <span class="inline-flex items-center gap-1 text-forest-700 text-sm font-semibold">
          Read blog
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </span>
      </a>
    <% }); %>
  </div>
</section>

