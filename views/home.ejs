<!-- ============ CONSULTATION BANNER ============ -->
<section class="max-w-7xl mx-auto px-6 pb-16">
  <div class="bg-ink-900 rounded-3xl p-8 md:p-14 relative overflow-hidden">

    <div class="relative z-10 max-w-2xl">
      <span class="inline-block px-3 py-1 rounded-capsule bg-mint-400/15 text-mint-400 text-xs font-semibold mb-4">Expert Guidance</span>
