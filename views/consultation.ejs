<%- include('partials/header') %> <%- include('partials/navbar') %>

<section class="max-w-7xl mx-auto px-6 pt-8">
  <nav class="text-sm text-ink-900/50 mb-4">
    <a href="/" class="hover:text-forest-700">Home</a>
    <span class="mx-1">&rsaquo;</span>
    <span class="text-ink-900">Book a Consultation</span>
  </nav>
  <h1 class="font-display text-3xl md:text-4xl font-semibold text-ink-900 mb-2">
    Consult an Expert
  </h1>
  <p class="text-ink-900/60 max-w-xl">
    Get personalized guidance from licensed professionals — online or in person.
  </p>
</section>

<section class="max-w-3xl mx-auto px-6 py-10" x-data="{ mode: 'online' }">
  <!-- Toggle -->
  <div class="flex gap-2 p-1 bg-mint-50 rounded-capsule w-fit mx-auto mb-10">
    <button
      @click="mode = 'online'"
      class="px-6 py-2.5 rounded-capsule text-sm font-semibold transition-colors flex items-center gap-2"
      :class="mode === 'online' ? 'bg-forest-700 text-white' : 'text-ink-900/60'"
    >
      <svg
        class="w-4 h-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"
        />
      </svg>
      Online Consultation
    </button>
    <button
      @click="mode = 'physical'"
      class="px-6 py-2.5 rounded-capsule text-sm font-semibold transition-colors flex items-center gap-2"
      :class="mode === 'physical' ? 'bg-forest-700 text-white' : 'text-ink-900/60'"
    >
      <svg
        class="w-4 h-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z"
        />
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
        />
      </svg>
      Visit In-Store
    </button>
  </div>

  <div class="bg-white border border-mint-200 rounded-3xl p-8">
    <!-- Topic -->
    <div class="mb-6">
      <label class="block text-sm font-medium text-ink-900 mb-1.5"
        >What would you like to discuss?</label
      >
      <select
        class="w-full px-4 py-2.5 rounded-xl border border-mint-200 text-sm focus:outline-none focus:ring-2 focus:ring-forest-700/20"
      >
        <option>Chronic Conditions</option>
        <option>Mental Health</option>
        <option>Skin & Dermatology</option>
        <option>Healthy Lifestyle</option>
        <option>Nutrition</option>
        <option>General Health Goals</option>
      </select>
    </div>

    <!-- Online-only fields -->
    <div
      x-show="mode === 'online'"
      x-cloak
      class="grid md:grid-cols-2 gap-5 mb-6"
    >
      <div>
        <label class="block text-sm font-medium text-ink-900 mb-1.5"
          >Preferred Date</label
        >
        <input
          type="date"
          class="w-full px-4 py-2.5 rounded-xl border border-mint-200 text-sm focus:outline-none focus:ring-2 focus:ring-forest-700/20"
        />
      </div>
      <div>
        <label class="block text-sm font-medium text-ink-900 mb-1.5"
          >Preferred Time</label
        >
        <input
          type="time"
          class="w-full px-4 py-2.5 rounded-xl border border-mint-200 text-sm focus:outline-none focus:ring-2 focus:ring-forest-700/20"
        />
      </div>
    </div>

    <!-- Physical-only fields -->
    <div x-show="mode === 'physical'" x-cloak class="mb-6">
      <label class="block text-sm font-medium text-ink-900 mb-1.5"
        >Choose a Branch</label
      >
      <select
        class="w-full px-4 py-2.5 rounded-xl border border-mint-200 text-sm focus:outline-none focus:ring-2 focus:ring-forest-700/20"
      >
        <option>Eldoret Branch</option>
        <option>Khayega Branch</option>
      </select>
    </div>

    <!-- Shared fields -->
    <div class="grid md:grid-cols-2 gap-5 mb-6">
      <div>
        <label class="block text-sm font-medium text-ink-900 mb-1.5"
          >Full Name</label
        >
        <input
          type="text"
          placeholder="Jane Doe"
          class="w-full px-4 py-2.5 rounded-xl border border-mint-200 text-sm focus:outline-none focus:ring-2 focus:ring-forest-700/20"
        />
      </div>
      <div>
        <label class="block text-sm font-medium text-ink-900 mb-1.5"
          >Phone Number</label
        >
        <input
          type="tel"
          placeholder="+254 7XX XXX XXX"
          class="w-full px-4 py-2.5 rounded-xl border border-mint-200 text-sm focus:outline-none focus:ring-2 focus:ring-forest-700/20"
        />
      </div>
      <div class="md:col-span-2">
        <label class="block text-sm font-medium text-ink-900 mb-1.5"
          >Notes
          <span class="text-ink-900/40 font-normal">(optional)</span></label
        >
        <textarea
          rows="3"
          placeholder="Briefly describe what you'd like to talk about..."
          class="w-full px-4 py-2.5 rounded-xl border border-mint-200 text-sm focus:outline-none focus:ring-2 focus:ring-forest-700/20"
        ></textarea>
      </div>
    </div>

    <button
      class="w-full py-3.5 rounded-capsule bg-forest-700 text-white font-semibold hover:bg-ink-900 transition-colors"
    >
      <span
        x-text="mode === 'online' ? 'Book Online Consultation' : 'Book In-Store Visit'"
      ></span>
    </button>
  </div>
</section>

<%- include('partials/bottom-nav') %> <%- include('partials/footer') %>
