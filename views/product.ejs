  </div>

  <!-- Product Info -->
  <div x-data="{ qty: 1 }">
    <span class="text-forest-700 font-semibold text-sm">Medicines &middot; Generic</span>
    <h1 class="font-display text-3xl font-semibold text-ink-900 mt-2 mb-3">Duromine 15mg Capsules 30's</h1>
    <p class="text-ink-900/60 mb-5 leading-relaxed">
