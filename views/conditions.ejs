<%- include('partials/header') %>
<%- include('partials/navbar') %>

<section class="max-w-7xl mx-auto px-6 pt-8">
  <nav class="text-sm text-ink-900/50 mb-4">
    <a href="/" class="hover:text-forest-700">Home</a> <span class="mx-1">&rsaquo;</span> <span class="text-ink-900">Shop by Condition</span>
  </nav>
  <h1 class="font-display text-3xl md:text-4xl font-semibold text-ink-900 mb-2">Shop by Condition</h1>
  <p class="text-ink-900/60 max-w-xl">Find products tailored to your specific health condition or concern.</p>
</section>

<section class="max-w-7xl mx-auto px-6 py-10">
  <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
    <% const conditions = [
      { name: 'Aches & Pains', slug: 'aches-pains' },
      { name: 'Acne', slug: 'acne' },
      { name: 'Allergy & Hayfever', slug: 'allergy-hayfever' },
      { name: 'Anti Infectives', slug: 'anti-infectives' },
      { name: 'Bites & Stings', slug: 'bites-stings' },
      { name: 'Cough, Cold & Flu', slug: 'cough-cold-flu' },
      { name: 'Dry Skin', slug: 'dry-skin' },
      { name: 'Eczema', slug: 'eczema' },
      { name: 'Eye and Ear Care', slug: 'eye-ear-care' },
      { name: 'First Aid & Bandages', slug: 'first-aid-bandages' },
      { name: 'Oily Skin', slug: 'oily-skin' },
      { name: 'Oral Care', slug: 'oral-care' },
    ]; %>
    <% conditions.forEach(function(c) { %>
      <a href="/condition/<%= c.slug %>" class="bg-white border border-mint-200 rounded-2xl p-5 flex items-center justify-between gap-3 hover:border-forest-700 hover:shadow-md transition-all group">
        <span class="font-semibold text-ink-900 text-sm"><%= c.name %></span>
        <svg class="w-4 h-4 text-ink-900/30 group-hover:text-forest-700 transition-colors shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      </a>
    <% }); %>
  </div>
</section>

<%- include('partials/bottom-nav') %>
<%- include('partials/footer') %>