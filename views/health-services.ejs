<%- include('partials/header') %>
<%- include('partials/navbar') %>

<section class="max-w-7xl mx-auto px-6 pt-8">
  <nav class="text-sm text-ink-900/50 mb-4">
    <a href="/" class="hover:text-forest-700">Home</a> <span class="mx-1">&rsaquo;</span> <span class="text-ink-900">Health Services</span>
  </nav>
  <h1 class="font-display text-3xl md:text-4xl font-semibold text-ink-900 mb-2">Health Services</h1>
  <p class="text-ink-900/60 max-w-xl">Beyond medicines — diagnostics, consultations, and care, all in one place.</p>
</section>

<section class="max-w-7xl mx-auto px-6 py-10">
  <div class="grid md:grid-cols-2 gap-5">
    <% const services = [
      { name: 'Lab Tests', desc: 'Book certified diagnostic tests with optional home sample collection.', icon: 'M9 3v2m6-2v2M4 8h16M5 8v11a2 2 0 002 2h10a2 2 0 002-2V8H5z', action: 'Book a Test' },
      { name: 'Vaccinations', desc: 'Stay protected with routine and travel vaccinations administered by licensed staff.', icon: 'M9 12.75L11.25 15 15 9.75M21 12c0 4.556-3.04 8.582-7.5 9.75C9.04 20.582 6 16.556 6 12V6.5l6-3 6 3V12z', action: 'Book Vaccination' },
      { name: 'Doctor Consultations', desc: 'Speak to a licensed doctor online or in-store about any health concern.', icon: 'M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z', action: 'Book Consultation' },
      { name: 'Diagnostics & Screening', desc: 'Blood pressure, glucose, cholesterol, and BMI checks available in-store.', icon: 'M3 12h4l2-7 4 14 2-7h6', action: 'Find a Store' },
    ]; %>
    <% services.forEach(function(s) { %>
      <div class="bg-white border border-mint-200 rounded-2xl p-6 flex gap-5">
        <span class="w-12 h-12 rounded-xl bg-mint-50 flex items-center justify-center shrink-0">
          <svg class="w-6 h-6 text-forest-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6"><path stroke-linecap="round" stroke-linejoin="round" d="<%= s.icon %>"/></svg>
        </span>
        <div>
          <h3 class="font-display text-lg font-semibold text-ink-900 mb-1.5"><%= s.name %></h3>
          <p class="text-sm text-ink-900/60 mb-4 leading-relaxed"><%= s.desc %></p>
          <a href="#" class="inline-flex items-center gap-1 text-forest-700 font-semibold text-sm hover:text-ink-900">
            <%= s.action %>
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    <% }); %>
  </div>
</section>

<%- include('partials/bottom-nav') %>
<%- include('partials/footer') %>